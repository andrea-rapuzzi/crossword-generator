---
export const prerender = false;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FDL Crossword — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&family=Rufina:wght@400;700&display=swap" />
  <style>
    @import '../styles/tokens.css';
    @import '../styles/admin.css';
  </style>
</head>
<body>

  <!-- Header -->
  <header class="header">
    <div class="header__logo">FDL <span>Crossword</span></div>

    <button id="btn-demo" class="btn btn--ghost btn--sm">Demo ✦</button>
    <button id="btn-preview" class="btn btn--ghost btn--sm" disabled>Anteprima ↗</button>
  </header>

  <main class="main">

    <!-- ─── Sidebar ─────────────────────────────────────────────────────── -->
    <aside class="sidebar">

      <!-- Lingua -->
      <section>
        <p class="section-title">Configurazione</p>
        <div class="field">
          <label for="lang">Lingua</label>
          <select id="lang" class="select">
            <option value="it">Italiano</option>
            <option value="en">English</option>
          </select>
        </div>
      </section>

      <hr class="divider" />

      <!-- URL input -->
      <section>
        <p class="section-title">Fonti</p>
        <div class="field">
          <label for="url-input">Aggiungi URL</label>
          <div style="display:flex; gap:var(--space-2)">
            <input
              id="url-input"
              type="url"
              class="input"
              placeholder="https://…"
            />
            <button id="btn-add-url" class="btn btn--secondary" title="Aggiungi">+</button>
          </div>
        </div>

        <!-- URL list -->
        <div id="url-list" class="url-list" style="margin-top:var(--space-3)">
          <p class="url-empty">Nessun URL aggiunto</p>
        </div>
      </section>

      <hr class="divider" />

      <!-- Actions -->
      <section style="display:flex; flex-direction:row; flex-wrap:wrap; gap:var(--space-3); align-items:center">
        <button id="btn-scrape" class="btn btn--pill btn--pill-blue" disabled="disabled">
          Scrape Contenuti
        </button>
        <button id="btn-generate" class="btn btn--pill btn--pill-navy" disabled>
          Genera Cruciverba
        </button>
      </section>

      <!-- Status + Log -->
      <section>
        <div class="status-panel">
          <div class="status-row">
            <span id="status-icon" class="status-icon"></span>
            <span id="status-label" class="status-label">Pronto</span>
          </div>
          <div class="progress-track">
            <div id="progress-fill" class="progress-fill"></div>
          </div>
          <div id="log" class="log">
            <span class="log__line">Pronto.</span>
          </div>
        </div>
      </section>

    </aside>

    <!-- ─── Content ──────────────────────────────────────────────────────── -->
    <section class="content">

      <!-- Words card -->
      <div class="card">
        <div class="card__header">
          <span class="card__title">Parole estratte</span>
          <div style="display:flex;align-items:center;gap:var(--space-3)">
            <span id="word-count" class="badge badge--blue" style="display:none"></span>
            <button id="btn-add-word" class="btn btn--secondary btn--sm">+ Aggiungi</button>
            <button id="btn-clear-words" class="btn btn--danger-ghost btn--sm" style="display:none">Svuota</button>
          </div>
        </div>

        <!-- Add word inline form -->
        <div id="add-word-form" class="add-word-form" style="display:none">
          <input id="add-answer" type="text"  class="input add-word-form__answer" placeholder="PAROLA"             aria-label="Parola" autocomplete="off" />
          <input id="add-clue"   type="text"  class="input" placeholder="Indizio…"      style="flex:1"             aria-label="Indizio" />
          <input id="add-hint"   type="text"  class="input" placeholder="Suggerimento…" style="flex:1"             aria-label="Suggerimento" />
          <input id="add-url"    type="url"   class="input add-word-form__url" placeholder="https://… (opzionale)" aria-label="URL fonte (opzionale)" />
          <button id="btn-add-word-ok"     class="btn btn--primary btn--sm">Aggiungi</button>
          <button id="btn-add-word-cancel" class="btn btn--secondary btn--sm">Annulla</button>
        </div>

        <div id="words-empty" class="words-empty-state">
          Le parole estratte dagli articoli appariranno qui.
        </div>

        <table id="words-table" class="words-table" style="display:none">
          <thead>
            <tr>
              <th class="col-priority" title="Priorità">★</th>
              <th>Parola</th>
              <th>Indizio</th>
              <th>Suggerimento</th>
              <th>Fonte</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="words-body"></tbody>
        </table>
      </div>

    </section>

  </main>

  <script>
    import '../scripts/admin.js';
  </script>
</body>
</html>
